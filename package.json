{
  "name": "koinonia-lite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "audit:ui-css": "node scripts/audit-ui-css-overrides.mjs",
    "audit:ui-css:strict": "node scripts/audit-ui-css-overrides.mjs --strict",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "verify": "npm run db:generate && npm run typecheck && npm run lint && npm run test && npm run build",
    "verify:e2e": "npm run db:generate && npm run test:e2e",
    "verify:all": "npm run verify && npm run audit:ui-css:strict && npm run test:e2e",
    "test:e2e:ui": "playwright test --ui",
    "screenshots:mobile": "playwright test tests/e2e/mobile-captures.spec.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:semear": "tsx prisma/seed-semear.ts",
    "db:studio": "prisma studio",
    "db:seed:active-sandbox": "tsx prisma/seed-active-sandbox.ts",
    "audit:ui-css:lows": "node scripts/audit-ui-css-overrides.mjs --low-review",
    "audit:ui-css:strict-all": "node scripts/audit-ui-css-overrides.mjs --strict --fail-on-low",
    "db:seed:performance": "tsx prisma/seed-performance.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.12",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "next": {
      "postcss": "8.5.12"
    }
  }
}
